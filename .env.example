# ShumelaHire Environment Variables
# Copy this file to .env and fill in all required values

# Spring Profile
SPRING_PROFILES_ACTIVE=production

# Database
DATABASE_URL=jdbc:postgresql://localhost:5432/shumelahire
DATABASE_USER=shumelahire
DATABASE_PASS=

# Security (REQUIRED — generate unique values, do not reuse defaults)
JWT_SECRET=
ENCRYPTION_KEY=

# Storage (local | s3)
STORAGE_PROVIDER=local
UPLOAD_DIR=uploads

# AWS S3 (required when STORAGE_PROVIDER=s3)
S3_BUCKET=shumelahire-documents
S3_REGION=af-south-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# DocuSign E-Signature
ESIGNATURE_PROVIDER=docusign
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_SECRET_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_WEBHOOK_HMAC_KEY=
DOCUSIGN_PRIVATE_KEY=
DOCUSIGN_AUTH_SERVER=https://account-d.docusign.com

# AWS SES
SES_ENABLED=false
SES_REGION=af-south-1
SES_FROM_EMAIL=noreply@shumelahire.co.za
SES_FROM_NAME=ShumelaHire

# Microsoft Graph (Teams + Outlook)
MICROSOFT_ENABLED=false
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
TEAMS_WEBHOOK_URL=
OUTLOOK_CALENDAR_USER=

# Job Boards
LINKEDIN_ENABLED=false
LINKEDIN_API_KEY=
LINKEDIN_API_SECRET=
LINKEDIN_ORG_ID=
INDEED_ENABLED=false
INDEED_EMPLOYER_ID=
INDEED_API_TOKEN=
PNET_ENABLED=false
PNET_API_KEY=
CAREER_JUNCTION_ENABLED=false
CAREER_JUNCTION_API_KEY=
CAREER_JUNCTION_PARTNER_ID=

# AI
AI_ENABLED=false
AI_PROVIDER=mock
CLAUDE_API_KEY=
OPENAI_API_KEY=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Cognito (required for non-dev profiles)
COGNITO_ISSUER_URI=

# SQS Notifications
NOTIFICATION_SQS_ENABLED=false
SQS_NOTIFICATION_QUEUE_URL=

# Data Residency
DATA_RESIDENCY_REGION=ZA
DATA_RESIDENCY_PROVIDER=local
