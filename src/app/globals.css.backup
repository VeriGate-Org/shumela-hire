@tailwind base;
@tailwind components;
@tailwind utilities;

/* Enterprise Theme System - CSS Variables */
:root {
  /* Base Light Theme */
  --background: #ffffff;
  --foreground: #0f172a;
  --card: #ffffff;
  --card-foreground: #0f172a;
  --popover: #ffffff;
  --popover-foreground: #0f172a;
  --primary: #3b82f6;
  --primary-foreground: #ffffff;
  --secondary: #f1f5f9;
  --secondary-foreground: #0f172a;
  --muted: #f1f5f9;
  --muted-foreground: #64748b;
  --accent: #f1f5f9;
  --accent-foreground: #0f172a;
  --destructive: #ef4444;
  --destructive-foreground: #ffffff;
  --border: #e2e8f0;
  --input: #e2e8f0;
  --ring: #3b82f6;
  --radius: 0.5rem;
  
  /* Design System Tokens */
  --font-sans: 'Inter', system-ui, sans-serif;
  --font-mono: 'Fira Code', Monaco, Consolas, monospace;
  --font-display: 'Cal Sans', 'Inter', system-ui, sans-serif;
  
  /* Spacing Scale */
  --space-xs: 0.5rem;
  --space-sm: 0.75rem;
  --space-md: 1rem;
  --space-lg: 1.5rem;
  --space-xl: 2rem;
  --space-2xl: 3rem;
  
  /* Shadow System */
  --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
  --shadow-base: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
  --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
  --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
  --shadow-xl: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);
  
  /* Animation Tokens */
  --animate-fast: 150ms;
  --animate-normal: 300ms;
  --animate-slow: 500ms;
  --ease-in-out: cubic-bezier(0.4, 0, 0.2, 1);
}

/* Dark Theme */
.dark {
  --background: #0a0a0a;
  --foreground: #fafafa;
  --card: #121212;
  --card-foreground: #fafafa;
  --popover: #0a0a0a;
  --popover-foreground: #fafafa;
  --primary: #3b82f6;
  --primary-foreground: #ffffff;
  --secondary: #262626;
  --secondary-foreground: #fafafa;
  --muted: #262626;
  --muted-foreground: #a3a3a3;
  --accent: #262626;
  --accent-foreground: #fafafa;
  --destructive: #ef4444;
  --destructive-foreground: #ffffff;
  --border: #262626;
  --input: #262626;
  --ring: #3b82f6;
  
  /* Dark mode shadows */
  --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.5);
  --shadow-base: 0 1px 3px 0 rgb(0 0 0 / 0.5), 0 1px 2px -1px rgb(0 0 0 / 0.5);
  --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.5), 0 2px 4px -2px rgb(0 0 0 / 0.5);
  --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.5), 0 4px 6px -4px rgb(0 0 0 / 0.5);
  --shadow-xl: 0 20px 25px -5px rgb(0 0 0 / 0.5), 0 8px 10px -6px rgb(0 0 0 / 0.5);
}

/* High Contrast Mode */
.high-contrast {
  --background: #ffffff;
  --foreground: #000000;
  --card: #ffffff;
  --card-foreground: #000000;
  --primary: #000000;
  --primary-foreground: #ffffff;
  --secondary: #ffffff;
  --secondary-foreground: #000000;
  --border: #000000;
  --ring: #000000;
}

.high-contrast.dark {
  --background: #000000;
  --foreground: #ffffff;
  --card: #000000;
  --card-foreground: #ffffff;
  --primary: #ffffff;
  --primary-foreground: #000000;
  --secondary: #000000;
  --secondary-foreground: #ffffff;
  --border: #ffffff;
  --ring: #ffffff;
}

/* Body Base Styles */
body {
  background: var(--background);
  color: var(--foreground);
  font-family: var(--font-sans);
  font-feature-settings: 'rlig' 1, 'calt' 1;
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  transition: background-color var(--animate-normal) var(--ease-in-out),
              color var(--animate-normal) var(--ease-in-out);
}

/* Role-specific Theme Classes */
.theme-executive {
  --primary: #4f46e5;
  --primary-foreground: #ffffff;
  --secondary: #f59e0b;
  --secondary-foreground: #ffffff;
  --accent: #eef2ff;
  --accent-foreground: #4f46e5;
  --ring: #4f46e5;
  --shadow-colored: 0 4px 14px 0 rgba(79, 70, 229, 0.25);
}

.theme-hr {
  --primary: #3b82f6;
  --primary-foreground: #ffffff;
  --secondary: #0ea5e9;
  --secondary-foreground: #ffffff;
  --accent: #eff6ff;
  --accent-foreground: #3b82f6;
  --ring: #3b82f6;
  --shadow-colored: 0 4px 14px 0 rgba(59, 130, 246, 0.25);
}

.theme-admin {
  --primary: #dc2626;
  --primary-foreground: #ffffff;
  --secondary: #737373;
  --secondary-foreground: #ffffff;
  --accent: #fef2f2;
  --accent-foreground: #dc2626;
  --ring: #dc2626;
  --shadow-colored: 0 4px 14px 0 rgba(220, 38, 38, 0.25);
}

.theme-hiring {
  --primary: #16a34a;
  --primary-foreground: #ffffff;
  --secondary: #84cc16;
  --secondary-foreground: #ffffff;
  --accent: #f0fdf4;
  --accent-foreground: #16a34a;
  --ring: #16a34a;
  --shadow-colored: 0 4px 14px 0 rgba(22, 163, 74, 0.25);
}

.theme-recruiter {
  --primary: #9333ea;
  --primary-foreground: #ffffff;
  --secondary: #d946ef;
  --secondary-foreground: #ffffff;
  --accent: #faf5ff;
  --accent-foreground: #9333ea;
  --ring: #9333ea;
  --shadow-colored: 0 4px 14px 0 rgba(147, 51, 234, 0.25);
}

.theme-applicant {
  --primary: #ea580c;
  --primary-foreground: #ffffff;
  --secondary: #f59e0b;
  --secondary-foreground: #ffffff;
  --accent: #fff7ed;
  --accent-foreground: #ea580c;
  --ring: #ea580c;
  --shadow-colored: 0 4px 14px 0 rgba(234, 88, 12, 0.25);
}

/* Enhanced Component Styles */
@layer base {
  * {
    border-color: var(--border);
  }
  
  body {
    background: var(--background);
    color: var(--foreground);
  }
  
  /* Focus styles for accessibility */
  *:focus-visible {
    outline: none;
    box-shadow: 0 0 0 2px var(--ring), 0 0 0 4px var(--background);
  }
  
  /* Improved button focus */
  button:focus-visible,
  [role="button"]:focus-visible {
    box-shadow: 0 0 0 2px var(--ring), 0 0 0 4px var(--background);
  }
  
  /* Enhanced form elements */
  input, select, textarea {
    transition: colors 200ms ease-in-out;
  }
  
  input:focus, select:focus, textarea:focus {
    box-shadow: 0 0 0 2px var(--ring), 0 0 0 4px var(--background);
  }
}

@layer components {
  /* Enterprise Card Component */
  .enterprise-card {
    background: var(--card);
    color: var(--card-foreground);
    border-radius: 0.75rem;
    border: 1px solid var(--border);
    box-shadow: var(--shadow-md);
    transition: all 300ms ease-in-out;
  }
  
  .enterprise-card:hover {
    box-shadow: var(--shadow-lg);
    border-color: rgb(209 213 219); /* gray-300 */
  }
  
  .enterprise-card-elevated {
    background: var(--card);
    color: var(--card-foreground);
    border-radius: 0.75rem;
    border: 1px solid var(--border);
    box-shadow: var(--shadow-lg);
    transition: all 300ms ease-in-out;
  }
  
  .enterprise-card-elevated:hover {
    box-shadow: var(--shadow-xl);
  }
  
  /* Enterprise Button Variants */
  .btn-primary {
    background: var(--primary);
    color: var(--primary-foreground);
    border-radius: 0.375rem;
    padding: 0.5rem 1rem;
    font-weight: 500;
    transition: all 200ms ease-in-out;
    border: none;
    cursor: pointer;
  }
  
  .btn-primary:hover {
    background: color-mix(in srgb, var(--primary) 90%, black);
  }
  
  .btn-primary:active {
    background: color-mix(in srgb, var(--primary) 85%, black);
  }
  
  .btn-primary:focus-visible {
    outline: none;
    box-shadow: 0 0 0 2px var(--primary), 0 0 0 4px var(--background);
  }
  
  .btn-secondary {
    background: var(--secondary);
    color: var(--secondary-foreground);
    border-radius: 0.375rem;
    padding: 0.5rem 1rem;
    font-weight: 500;
    transition: all 200ms ease-in-out;
    border: none;
    cursor: pointer;
  }
  
  .btn-secondary:hover {
    background: color-mix(in srgb, var(--secondary) 80%, black);
  }
  
  .btn-secondary:active {
    background: color-mix(in srgb, var(--secondary) 70%, black);
  }
  
  .btn-secondary:focus-visible {
    outline: none;
    box-shadow: 0 0 0 2px var(--secondary), 0 0 0 4px var(--background);
  }
  
  .btn-outline {
    background: transparent;
    color: var(--primary);
    border: 2px solid var(--primary);
    border-radius: 0.375rem;
    padding: 0.5rem 1rem;
    font-weight: 500;
    transition: all 200ms ease-in-out;
    cursor: pointer;
  }
  
  .btn-outline:hover {
    background: var(--primary);
    color: var(--primary-foreground);
  }
  
  .btn-outline:focus-visible {
    outline: none;
    box-shadow: 0 0 0 2px var(--primary), 0 0 0 4px var(--background);
  }
  
  /* Enterprise Navigation */
  .nav-primary {
    background: color-mix(in srgb, var(--card) 95%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
  }
  
  .nav-item {
    color: var(--muted-foreground);
    transition: color 200ms ease-in-out;
  }
  
  .nav-item:hover {
    color: var(--foreground);
  }
  
  .nav-item-active {
    color: var(--primary);
    border-bottom: 2px solid var(--primary);
  }
}

/* Animation Classes */
.animate-fade-in {
  animation: fade-in var(--animate-normal) var(--ease-in-out);
}

.animate-slide-up {
  animation: slide-up var(--animate-normal) var(--ease-in-out);
}

.animate-scale-in {
  animation: scale-in var(--animate-normal) var(--ease-in-out);
}

@keyframes fade-in {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slide-up {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes scale-in {
  from {
    opacity: 0;
    transform: scale(0.95);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

/* Enterprise Loading States */
.loading-shimmer {
  background: linear-gradient(
    90deg,
    var(--muted) 25%,
    var(--accent) 50%,
    var(--muted) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 2s infinite;
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

/* Accessibility Enhancements */
@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}

@media (prefers-contrast: high) {
  :root {
    --border: #000000;
    --ring: #000000;
  }
  
  .dark {
    --border: #ffffff;
    --ring: #ffffff;
  }
}

/* Print Styles */
@media print {
  * {
    background: white !important;
    color: black !important;
    box-shadow: none !important;
  }
  
  .no-print {
    display: none !important;
  }
}

/* Mobile-first responsive utilities */
.mobile-scroll-container {
  -webkit-overflow-scrolling: touch;
  overscroll-behavior: contain;
}

.mobile-safe-area {
  padding-bottom: env(safe-area-inset-bottom);
  padding-left: env(safe-area-inset-left);
  padding-right: env(safe-area-inset-right);
}

/* Touch-friendly interactions */
.touch-target {
  min-height: 44px;
  min-width: 44px;
}

/* Smooth animations for mobile */
.mobile-transition {
  transition: transform 0.2s ease-out, opacity 0.2s ease-out;
}

/* Prevent zoom on double-tap */
.no-zoom {
  touch-action: manipulation;
}

/* Custom animations */
@keyframes slide-up {
  from {
    transform: translateY(100%);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.animate-slide-up {
  animation: slide-up 0.3s ease-out;
}

@keyframes fade-in {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.animate-fade-in {
  animation: fade-in 0.2s ease-out;
}

/* Loading states */
.loading-shimmer {
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 2s infinite;
}

@keyframes shimmer {
  0% {
    background-position: -200% 0;
  }
  100% {
    background-position: 200% 0;
  }
}

/* Offline indicators */
.offline-badge {
  position: relative;
}

.offline-badge::after {
  content: '';
  position: absolute;
  top: -2px;
  right: -2px;
  width: 8px;
  height: 8px;
  background: #f59e0b;
  border-radius: 50%;
  border: 2px solid white;
}

/* Custom scrollbar for webkit browsers */
.custom-scrollbar::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

.custom-scrollbar::-webkit-scrollbar-track {
  background: #f1f1f1;
  border-radius: 3px;
}

.custom-scrollbar::-webkit-scrollbar-thumb {
  background: #c1c1c1;
  border-radius: 3px;
}

.custom-scrollbar::-webkit-scrollbar-thumb:hover {
  background: #a8a8a8;
}

/* High contrast mode support */
@media (prefers-contrast: high) {
  .border-gray-200 {
    border-color: #000000;
  }
  
  .text-gray-600 {
    color: #000000;
  }
}

/* Reduced motion support */
@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}
